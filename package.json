{
  "name": "exhibits-london-app",
  "version": "1.0.0",
  "description": "London Exhibitions - Azure Static Web App",
  "scripts": {
    "dev": "swa start http://localhost:5173 --run \"npm run dev:frontend\" --api-location ./api",
    "dev:frontend": "cd exhibits-london && npm run dev",
    "dev:api": "cd api && func start",
    "build": "cd exhibits-london && npm run build",
    "install:all": "npm install && cd exhibits-london && npm install && cd ../api && npm install",
    "swa:start": "swa start"
  },
  "keywords": [
    "azure",
    "static-web-apps",
    "exhibitions"
  ],
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.9",
    "@types/node": "^26.1.1",
    "eslint-plugin-typescript": "^0.14.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "date-fns": "^4.2.1",
    "mapbox-gl": "^3.25.0",
    "react-map-gl": "^8.1.1"
  }
}
